# Copy to ".env" in this folder, then restart the HDRI API (uvicorn).
# Shell environment variables still win if already set.

# --- Current architecture: notebook API + public domain + RunComfy GPU ---
# Blender calls https://api.richardandrys.com — notebook runs uvicorn; tunnel gives HTTPS.
# Full steps: ../NOTEBOOK_DOMAIN_SETUP.md
#
# HDRI_PUBLIC_BASE_URL=https://api.richardandrys.com
# HDRI_SIGNING_SECRET=<long-random>
# HDRI_REQUIRE_API_KEY=1
# HDRI_ADMIN_TOKEN=<admin-only>
# HDRI_REMOTE_PROVIDER=runcomfy
# RUNCOMFY_API_TOKEN=...
# RUNCOMFY_DEPLOYMENT_ID=...

# V1 local-first default: external worker (ComfyUI bridge)
PANORAMA_MODE=http_json
PANORAMA_HTTP_URL=http://127.0.0.1:8001/v1/panorama

# Remote provider adapter mode:
# - legacy: use existing PANORAMA_MODE backends (resize/replicate/http_json/hf_dit360)
# - runcomfy: submit and poll hosted RunComfy deployment API
# HDRI_REMOTE_PROVIDER=legacy

# RunComfy hosted workflow provider (used when HDRI_REMOTE_PROVIDER=runcomfy)
# RUNCOMFY_API_TOKEN=
# RUNCOMFY_DEPLOYMENT_ID=
# RUNCOMFY_BASE_URL=https://api.runcomfy.net
# Optional: send full workflow_api_json from local file each request
# RUNCOMFY_WORKFLOW_JSON_PATH=examples/workflow_api.json
# RUNCOMFY_POLL_TIMEOUT_S=900
# Optional static per-request overrides baseline
# RUNCOMFY_OVERRIDES_JSON={"12":{"inputs":{"steps":24}}}
# Optional node-id mappings for generic API fields -> workflow inputs
# RUNCOMFY_IMAGE_NODE_IDS=5
# RUNCOMFY_PROMPT_NODE_IDS=17
# RUNCOMFY_NEGATIVE_PROMPT_NODE_IDS=18
# RUNCOMFY_SEED_NODE_IDS=24
# RUNCOMFY_STRENGTH_NODE_IDS=24
# RUNCOMFY_REFERENCE_COVERAGE_NODE_IDS=33
# RUNCOMFY_DIMENSION_NODE_IDS=42
# RUNCOMFY_STEPS_NODE_IDS=24

# Job/auth/accounting store
# HDRI_DB_PATH=.\data\state.sqlite3
# Require Bearer API key on /v1/hdri, /v1/jobs/* and /v1/account
# HDRI_REQUIRE_API_KEY=1
# Optional local bootstrap key for development only
# HDRI_BOOTSTRAP_API_KEY=dev-secret-key
# HDRI_BOOTSTRAP_ACCOUNT_ID=dev-account
# HDRI_BOOTSTRAP_TOKENS=25
# Concurrency guard per account for async jobs
# HDRI_MAX_ACTIVE_JOBS_PER_ACCOUNT=2
# Reaper settings for stale jobs (auto-fail + auto-refund)
# HDRI_STALE_REAPER_INTERVAL_S=30
# HDRI_STALE_JOB_TIMEOUT_S=900
# Admin API enablement for account provisioning endpoint POST /v1/accounts
# HDRI_ADMIN_TOKEN=change-me

# HDR reconstruction stage after panorama generation
HDR_RECONSTRUCTION_MODE_DEFAULT=comfyui_hdr
# If HDR path errors, fallback mode: heuristic | off
AI_HDR_FAILOVER_MODE=heuristic
# AI backend selector for ai_fast mode: embedded | torchscript
AI_HDR_MODEL_NAME=embedded
# Required only when AI_HDR_MODEL_NAME=torchscript
# AI_HDR_MODEL_PATH=D:\models\ai_hdr_model.ts
# AI_HDR_DEVICE=cuda
# ComfyUI HDR restore worker (required when HDR_RECONSTRUCTION_MODE_DEFAULT=comfyui_hdr)
# Must match panorama worker POST /v1/hdr_restore (examples/comfyui_worker.py on port 8001).
HDR_HTTP_URL=http://127.0.0.1:8001/v1/hdr_restore
# HDR_HTTP_TIMEOUT_S=300
# HDR_HTTP_API_KEY=
# HDR_HTTP_HEADERS_JSON=
# HDR_HTTP_BODY_JSON=

# Optional auth/headers when worker is remote
# PANORAMA_HTTP_API_KEY=
# PANORAMA_HTTP_HEADERS_JSON={"X-Custom":"1"}

# ComfyUI worker env (used by examples/comfyui_worker.py)
# COMFYUI_SERVER_URL=http://127.0.0.1:8188
# COMFYUI_WORKFLOW_TEMPLATE=examples/comfyui_flux2_klein_template.json
# Default HDR = GMNet (no second Flux). For Flux img2img HDR instead: comfyui_flux2_klein_4b_hdr_restore_api.json
# COMFYUI_HDR_WORKFLOW_TEMPLATE=examples/comfyui_gmnet_hdr_restore_api.json
# Optional overrides (prefer values inside exported API workflow JSON)
# COMFYUI_BASE_MODEL=flux-2-klein-base-4b.safetensors
# COMFYUI_KLEIN_LORA=flux-2-klein-4B-360-erp-outpaint-lora\flux-2-klein-4B-360-erp-outpaint-lora_V1.safetensors
# COMFYUI_BALANCED_STEPS=28
# COMFYUI_DEFAULT_STRENGTH=1.0
# COMFYUI_HDR_BALANCED_STEPS=28
# COMFYUI_HDR_DEFAULT_STRENGTH=0.35
# ComfyUI worker panorama post-step: left/right seam blend (default off). Set to 1 to restore old default when seam_fix is omitted.
# COMFYUI_SEAM_FIX_DEFAULT=0

# Alternative provider: Replicate baseline
# PANORAMA_MODE=replicate
# REPLICATE_API_TOKEN=r8_...
# REPLICATE_MODEL_VERSION=5f638558adec78589e947290cb7083b0730dcfc8e8c9c9db6eebc5261edc09ca
# REPLICATE_IMAGE_FIELD=image
